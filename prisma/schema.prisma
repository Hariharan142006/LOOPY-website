generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  email     String?  @unique
  phone     String?  @unique
  password  String
  image     String?
  role      String   @default("CUSTOMER") // CUSTOMER, AGENT, ADMIN, DELIVERY
  status    String   @default("ACTIVE") // ACTIVE, BLOCKED

  // Agent/Delivery fields
  vehicleType String?
  currentLat  Float?
  currentLng  Float?
  isOnline    Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses        Address[]
  bookings         Booking[]     @relation("CustomerBookings")
  assignedBookings Booking[]     @relation("AgentBookings")
  
  // Wallet
  walletBalance Float @default(0.0)
  transactions  WalletTransaction[]
  
  // Settings
  onboarded               Boolean @default(false)
  biometricsEnabled       Boolean @default(false)
  appNotificationsEnabled Boolean @default(true)
  preferredLanguage       String  @default("en")

  reviewsWritten Review[] @relation("WrittenReviews")
  reviewsReceived Review[] @relation("ReceivedReviews")
  notifications  Notification[]
  
  assignedVehicles FleetVehicle[]
  supportTickets   SupportTicket[]
  messagesSent     SupportMessage[] @relation("MessageSender")
}

model WalletTransaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId // The user whose wallet is affected
  amount      Float
  type        String   // CREDIT, DEBIT
  reference   String?  // Booking ID or "ADMIN_FUND"
  description String?
  
  relatedUserId String? @db.ObjectId // Admin who added funds OR Agent who paid OR Customer who received
  
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model Address {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  userId    String  @db.ObjectId
  label     String? // Home, Office
  street    String
  city      String
  state     String
  zip       String
  lat       Float
  lng       Float
  
  user      User    @relation(fields: [userId], references: [id])
  bookings  Booking[]
}

model ScrapCategory {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String
  image String?
  items ScrapItem[]
}

model ScrapItem {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  categoryId   String        @db.ObjectId
  name         String
  description  String?
  basePrice    Float
  currentPrice Float
  unit         String        @default("kg")
  image        String?
  
  category     ScrapCategory @relation(fields: [categoryId], references: [id])
  bookingItems BookingItem[]
}

model Booking {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  agentId     String?  @db.ObjectId
  addressId   String   @db.ObjectId
  
  status      String   @default("PENDING") // PENDING, ASSIGNED, ONEWAY, ARRIVED, WEIGHED, PAID, COMPLETED, CANCELLED
  scheduledAt DateTime
  
  totalAmount Float?
  
  // Snapshot of location in case address changes
  pickupLat   Float
  pickupLng   Float
  
  remarks     String?
  
  items       BookingItem[]
  
  evidenceImages String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  user        User     @relation("CustomerBookings", fields: [userId], references: [id])
  agent       User?    @relation("AgentBookings", fields: [agentId], references: [id])
  address     Address  @relation(fields: [addressId], references: [id])
  
  review      Review?
}

model BookingItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  bookingId   String   @db.ObjectId
  itemId      String   @db.ObjectId
  
  quantity    Float    // Estimated weight
  priceAtBooking Float // Price locked
  
  booking     Booking  @relation(fields: [bookingId], references: [id])
  item        ScrapItem @relation(fields: [itemId], references: [id])
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  bookingId String   @unique @db.ObjectId
  booking   Booking  @relation(fields: [bookingId], references: [id])

  customerId String  @db.ObjectId
  customer   User    @relation("WrittenReviews", fields: [customerId], references: [id])

  agentId    String  @db.ObjectId
  agent      User    @relation("ReceivedReviews", fields: [agentId], references: [id])
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  title     String
  message   String
  type      String   @default("INFO") // INFO, SUCCESS, WARNING, ERROR
  relatedId String?  // ID of booking or transaction for deep-linking
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())


  user      User     @relation(fields: [userId], references: [id])
}

model Company {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  type         String   @default("PARTNER") // PARTNER, FRANCHISE, CLIENT
  contactEmail String?
  contactPhone String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Warehouse {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  location  String
  lat       Float?
  lng       Float?
  capacity  Float?   // in kg or tons
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FleetVehicle {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  licensePlate String   @unique
  vehicleType  String
  capacityKg   Float?
  status       String   @default("ACTIVE") // ACTIVE, MAINTENANCE
  agentId      String?  @db.ObjectId      // Link a vehicle directly to an agent
  
  agent        User?    @relation(fields: [agentId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LocationZone {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  region    String
  lat       Float?
  lng       Float?
  radiusKm  Float?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupportTicket {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  subject   String
  status    String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority  String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  messages  SupportMessage[]
}

model SupportMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  ticketId  String   @db.ObjectId
  senderId  String   @db.ObjectId
  text      String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
  sender    User          @relation("MessageSender", fields: [senderId], references: [id])
}

model ReferralConfig {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  rewardAmount Float    @default(50.0)
  referralCode String?  @unique
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Otp {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  contact   String   // email or phone
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([contact])
}
